{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": false,
    "noImplicitAny": false,
    "checkJs": false,
    "allowUnreachableCode": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": []
}
